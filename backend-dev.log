prisma:query SELECT "public"."attendance_sessions"."id", "public"."attendance_sessions"."course_section_id", "public"."attendance_sessions"."lesson_id", "public"."attendance_sessions"."status"::text, "public"."attendance_sessions"."nonce", "public"."attendance_sessions"."opened_at", "public"."attendance_sessions"."closed_at", "public"."attendance_sessions"."created_by_id" FROM "public"."attendance_sessions" WHERE "public"."attendance_sessions"."status" = CAST($1::text AS "public"."SessionStatus") OFFSET $2
prisma:query SELECT "public"."lessons"."id", "public"."lessons"."course_section_id", "public"."lessons"."lesson_date", "public"."lessons"."start_time", "public"."lessons"."end_time", "public"."lessons"."room", "public"."lessons"."topic", "public"."lessons"."created_at" FROM "public"."lessons" WHERE "public"."lessons"."id" IN ($1,$2,$3,$4,$5,$6,$7,$8,$9) OFFSET $10
